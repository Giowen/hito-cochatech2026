# Copiá este archivo como `.env` (en esta misma carpeta) y completá los valores.
# El `.env` está gitignored — NUNCA se commitea (contiene el API key secreto).

# Públicos (los mismos que van en el cliente Flutter):
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=6a18a20b0034d04e659e

# SECRETO — el API key que creaste en la consola (scope databases/collections/attributes/indexes/buckets):
APPWRITE_API_KEY=pegá-aquí-tu-api-key-secreto

# ID lógico de la base de datos (lo crea el script; podés dejar este valor):
APPWRITE_DATABASE_ID=hito
