GROQ_API_KEY=your-groq-key-here

# OpenRouter (preferred for chat — sin rate limits, pay-as-you-go).
# Si está presente, chat/chatStream se rutean a OpenRouter.
# Whisper transcribe siempre va a Groq (OpenRouter no expone audio).
# OPENROUTER_API_KEY=sk-or-v1-...

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-here

# Appwrite (públicos — van en el cliente Flutter). El proyecto se autoriza por
# plataforma registrada en la consola (hostname/package), no por API key.
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_DATABASE_ID=hito

# Cloudflare R2 (Phase 2 — see lib/services/asset_storage.dart)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET=hito-assets
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev
